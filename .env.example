# =============================================================================
# NihongoDev Platform - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# --- Base de donnees (PostgreSQL) ---
POSTGRES_DB=nihongodev
POSTGRES_USER=nihongodev
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Connexion DB (pour Spring Boot) ---
DATABASE_URL=jdbc:postgresql://postgres:5432/nihongodev
DATABASE_USERNAME=nihongodev
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HOST=localhost

# --- Securite (JWT) ---
# IMPORTANT: Minimum 64 caracteres, generer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-app-password

# --- IA / LLM (Anthropic Claude) ---
LLM_API_KEY=sk-ant-api03-VOTRE_CLE
LLM_MODEL=claude-sonnet-4-6-20250514

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://votre-domaine.com

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod
